# Copy this file to .env and fill in real values. Never commit .env.

# ===== LLM =====
# Pick one provider: gemini | lightning | openai

# --- Option A: Lightning AI (OpenAI-compatible, generous quota) ---
LLM_PROVIDER=lightning
LLM_MODEL=lightning-ai/gpt-oss-120b
LLM_BASE_URL=https://lightning.ai/api/v1
LLM_API_KEY=your_lightning_token

# --- Option B: Gemini ---
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.5-flash
# GEMINI_API_KEY=your_gemini_key_from_aistudio.google.com

# --- Option C: OpenAI ---
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...

# Optional: Groq fallback (kept for compatibility with original NileTel code)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ===== Embedding & reranker models =====
EMBEDDING_MODEL=intfloat/multilingual-e5-large

# Reranker. Default fits in 4 GB GPUs (e.g. GTX 1650).
# For deployments with > 6 GB VRAM, the larger model gives better recall:
#   RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_MODEL=BAAI/bge-reranker-base

# Device for the reranker. "cuda" uses GPU if available (auto-falls-back to CPU).
# Embedder always runs on CPU.
RERANKER_DEVICE=cuda

# ===== Paths (relative to project root) =====
DATA_DIR=data
ARTIFACTS_DIR=artifacts

# ===== Retrieval tuning =====
DENSE_TOP_K=20
BM25_TOP_K=20
RRF_K=60
RERANK_TOP_K=5
MIN_SCORE=0.0

# ===== Chunking =====
CHUNK_MAX_CHARS=700

# ===== n8n integration =====
N8N_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/ticket
N8N_TIMEOUT_SECONDS=5

# ===== Session memory =====
SESSION_MAX_TURNS=3

# ===== App =====
LOG_LEVEL=INFO
